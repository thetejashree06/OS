#include <stdio.h>
#include <string.h>

int main() {
    FILE *fp;
    char line[100], word[20];
    int lineNo = 1;

    printf("Enter word to search: ");
    scanf("%s", word);

    fp = fopen("file.txt", "r");

    printf("\n---------------------------------------------\n");
    printf("| Line No | Matching Line                   |\n");
    printf("---------------------------------------------\n");

    while (fgets(line, sizeof(line), fp)) {
        if (strstr(line, word)) {
            printf("| %-7d | %-30s |\n", lineNo, line);
        }
        lineNo++;
    }

    printf("---------------------------------------------\n");

    fclose(fp);
    return 0;
}
